{
  "name": "@namescanner/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@namescanner/adapters-brave": "workspace:*",
    "@namescanner/adapters-godaddy": "workspace:*",
    "@namescanner/adapters-github": "workspace:*",
    "@namescanner/adapters-namecheap": "workspace:*",
    "@namescanner/adapters-rdap": "workspace:*",
    "@namescanner/adapters-stub": "workspace:*",
    "@namescanner/application": "workspace:*",
    "@namescanner/config": "workspace:*",
    "@namescanner/contracts": "workspace:*",
    "hono": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "tsx": "^4.20.3",
    "vitest": "^3.2.4"
