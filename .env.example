# --- API (apps/api) ---
API_PORT=3001
WEB_ORIGIN=http://localhost:5173
NODE_ENV=development

# Probe orchestration
PROBE_TIMEOUT_MS=3000
CACHE_TTL_DOMAIN_SEC=600
# stub = simulated probes (local dev). live = real adapters (production default)
PROBE_MODE=live

# Domain availability (live mode — public RDAP aggregator)
RDAP_BASE_URL=https://rdap.cloud/api/v1

# Web collision (v1 — Brave Search)
BRAVE_SEARCH_API_KEY=

# Registrar pricing (live mode — optional; stub mode uses mock INR prices)
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_CLIENT_IP=
NAMECHEAP_SANDBOX=false
USD_TO_INR_RATE=83
