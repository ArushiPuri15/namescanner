# --- API (apps/api) ---
API_PORT=3001
WEB_ORIGIN=http://localhost:5173
NODE_ENV=development

# Probe orchestration
PROBE_TIMEOUT_MS=3000
CACHE_TTL_DOMAIN_SEC=600
# stub = simulated probes (local dev). live = real adapters (production default)
PROBE_MODE=stub

# Domain availability (live mode)
# GoDaddy — preferred when buying domains there (availability + price per domain)
GODADDY_API_KEY=
GODADDY_API_SECRET=
GODADDY_API_ENV=ote

# RDAP fallback when GoDaddy credentials are not set
RDAP_BASE_URL=https://rdap.cloud/api/v1

# Web collision (live mode — Brave Search)
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_BASE_URL=https://api.search.brave.com/res/v1/web/search

# GitHub handle probe (optional token for higher rate limits)
GITHUB_API_TOKEN=

# Registrar pricing (live mode — optional; stub mode uses mock INR prices)
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_CLIENT_IP=
NAMECHEAP_SANDBOX=false
USD_TO_INR_RATE=83
